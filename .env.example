APP_NAME=PideAqui
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Mexico_City
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de datos (Sail configura estos valores automaticamente) ---
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# En produccion: SESSION_SECURE_COOKIE=true y SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Email (notificaciones de nuevos pedidos) ---
# En desarrollo usar 'log'. En produccion configurar SMTP real.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Storage: 'public' (local) o 's3' (AWS S3 / compatible)
MEDIA_DISK=public

# --- Google Maps ---
# VITE_ = frontend (mapas en panel admin: sucursales, detalle pedido, mapa operativo)
# GOOGLE_MAPS_API_KEY = backend (calculo de distancia real via Distance Matrix API)
# Pueden ser la misma key, pero en produccion se recomienda separar con restricciones distintas.
VITE_GOOGLE_MAPS_KEY=
GOOGLE_MAPS_API_KEY=

VITE_APP_NAME="${APP_NAME}"

# --- Laravel Reverb (WebSockets) ---
# En desarrollo local, generar con: php artisan reverb:generate-keys
# En Laravel Cloud, estas variables se inyectan automaticamente.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
